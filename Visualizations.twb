              <calculation class='tableau' formula='IF SUM([BigLawIncreaseDot (copy)_0599237686935564]) &gt; LOOKUP(SUM([BigLawIncreaseDot (copy)_0599237686935564]), -1) &#13;&#10;    OR SUM([Calculation_0599237687087117]) &gt; LOOKUP(SUM([Calculation_0599237687087117]), -1)&#13;&#10;    THEN AVG([firearm_homicide_rate])&#13;&#10;ELSE NULL&#13;&#10;END'>
