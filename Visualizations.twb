      <column caption='StateAbbreviation' datatype='string' name='[Calculation_0432662601064448]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [state]&#13;&#10;WHEN &quot;Alabama&quot; THEN &quot;AL&quot;&#13;&#10;WHEN &quot;Alaska&quot; THEN &quot;AK&quot;&#13;&#10;WHEN &quot;Arizona&quot; THEN &quot;AZ&quot;&#13;&#10;WHEN &quot;Arkansas&quot; THEN &quot;AR&quot;&#13;&#10;WHEN &quot;California&quot; THEN &quot;CA&quot;&#13;&#10;WHEN &quot;Colorado&quot; THEN &quot;CO&quot;&#13;&#10;WHEN &quot;Connecticut&quot; THEN &quot;CT&quot;&#13;&#10;WHEN &quot;Delaware&quot; THEN &quot;DE&quot;&#13;&#10;WHEN &quot;Florida&quot; THEN &quot;FL&quot;&#13;&#10;WHEN &quot;Georgia&quot; THEN &quot;GA&quot;&#13;&#10;WHEN &quot;Hawaii&quot; THEN &quot;HI&quot;&#13;&#10;WHEN &quot;Idaho&quot; THEN &quot;ID&quot;&#13;&#10;WHEN &quot;Illinois&quot; THEN &quot;IL&quot;&#13;&#10;WHEN &quot;Indiana&quot; THEN &quot;IN&quot;&#13;&#10;WHEN &quot;Iowa&quot; THEN &quot;IA&quot;&#13;&#10;WHEN &quot;Kansas&quot; THEN &quot;KS&quot;&#13;&#10;WHEN &quot;Kentucky&quot; THEN &quot;KY&quot;&#13;&#10;WHEN &quot;Louisiana&quot; THEN &quot;LA&quot;&#13;&#10;WHEN &quot;Maine&quot; THEN &quot;ME&quot;&#13;&#10;WHEN &quot;Maryland&quot; THEN &quot;MD&quot;&#13;&#10;WHEN &quot;Massachusetts&quot; THEN &quot;MA&quot;&#13;&#10;WHEN &quot;Michigan&quot; THEN &quot;MI&quot;&#13;&#10;WHEN &quot;Minnesota&quot; THEN &quot;MN&quot;&#13;&#10;WHEN &quot;Mississippi&quot; THEN &quot;MS&quot;&#13;&#10;WHEN &quot;Missouri&quot; THEN &quot;MO&quot;&#13;&#10;WHEN &quot;Montana&quot; THEN &quot;MT&quot;&#13;&#10;WHEN &quot;Nebraska&quot; THEN &quot;NE&quot;&#13;&#10;WHEN &quot;Nevada&quot; THEN &quot;NV&quot;&#13;&#10;WHEN &quot;New Hampshire&quot; THEN &quot;NH&quot;&#13;&#10;WHEN &quot;New Jersey&quot; THEN &quot;NJ&quot;&#13;&#10;WHEN &quot;New Mexico&quot; THEN &quot;NM&quot;&#13;&#10;WHEN &quot;New York&quot; THEN &quot;NY&quot;&#13;&#10;WHEN &quot;North Carolina&quot; THEN &quot;NC&quot;&#13;&#10;WHEN &quot;North Dakota&quot; THEN &quot;ND&quot;&#13;&#10;WHEN &quot;Ohio&quot; THEN &quot;OH&quot;&#13;&#10;WHEN &quot;Oklahoma&quot; THEN &quot;OK&quot;&#13;&#10;WHEN &quot;Oregon&quot; THEN &quot;OR&quot;&#13;&#10;WHEN &quot;Pennsylvania&quot; THEN &quot;PA&quot;&#13;&#10;WHEN &quot;Rhode Island&quot; THEN &quot;RI&quot;&#13;&#10;WHEN &quot;South Carolina&quot; THEN &quot;SC&quot;&#13;&#10;WHEN &quot;South Dakota&quot; THEN &quot;SD&quot;&#13;&#10;WHEN &quot;Tennessee&quot; THEN &quot;TN&quot;&#13;&#10;WHEN &quot;Texas&quot; THEN &quot;TX&quot;&#13;&#10;WHEN &quot;Utah&quot; THEN &quot;UT&quot;&#13;&#10;WHEN &quot;Vermont&quot; THEN &quot;VT&quot;&#13;&#10;WHEN &quot;Virginia&quot; THEN &quot;VA&quot;&#13;&#10;WHEN &quot;Washington&quot; THEN &quot;WA&quot;&#13;&#10;WHEN &quot;West Virginia&quot; THEN &quot;WV&quot;&#13;&#10;WHEN &quot;Wisconsin&quot; THEN &quot;WI&quot;&#13;&#10;WHEN &quot;Wyoming&quot; THEN &quot;WY&quot;&#13;&#10;ELSE &quot;DC&quot;&#13;&#10;END' />
      </column>
      <column caption='StateSelected' datatype='boolean' name='[Calculation_0599237633359872]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[state]=[Parameters].[Parameter 1]' />
      </column>
      <column caption='Lawchange' datatype='real' name='[Calculation_0599237633671169]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([lawtotal]) - LOOKUP(AVG([lawtotal]), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='BigLawIncreaseDot' datatype='real' name='[Calculation_0599237636177924]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_0599237633671169] &gt;=3&#13;&#10;THEN AVG([firearm_homicide_rate])&#13;&#10;ELSE NULL&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='PublicLawScore' datatype='integer' name='[Calculation_0599237674713094]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[universal] + [gvro] + [assault]' />
      </column>
      <column caption='EvidenceLawScore' datatype='integer' name='[Calculation_0599237674930183]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[permit] + [waiting] + [mcdv]' />
      </column>
      <column caption='LawGroupLabel' datatype='string' name='[Calculation_0599237675544585]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0599237674713094] &gt;= 2 AND [Calculation_0599237674930183] &gt;= 2&#13;&#10;    THEN &quot;Both Groups&quot;&#13;&#10;ELSEIF [Calculation_0599237674713094] &gt;= 2 AND [Calculation_0599237674930183] &lt; 2&#13;&#10;    THEN &quot;Popular Laws Only&quot;&#13;&#10;ELSEIF [Calculation_0599237674930183] &gt;= 2 AND [Calculation_0599237674713094] &lt; 2 &#13;&#10;    THEN &quot;Evidence Laws Only&quot;&#13;&#10;ELSE &quot;Weak Laws (neither group)&quot;&#13;&#10;END' />
      </column>
      <column caption='ScatterColor' datatype='string' name='[Calculation_0599237682192394]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &quot;Law Type Group&quot; &#13;&#10;    THEN [Calculation_0599237675544585]&#13;&#10;ELSE [Calculation_0118475816886273]&#13;&#10;END' />
      </column>
      <column caption='TopStatesCalc' datatype='boolean' name='[Calculation_0599237683810309]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(AVG([firearm_homicide_rate])) &lt; [Parameters].[Parameter 2]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='EvidenceLawScoreRaw' datatype='integer' name='[Calculation_0599237687087117]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[permit] + [waiting] + [mcdv]' />
      </column>
      <column caption='PopularLawDot' datatype='real' name='[Calculation_0599237687230478]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([BigLawIncreaseDot (copy)_0599237686935564]) &gt; LOOKUP(SUM([BigLawIncreaseDot (copy)_0599237686935564]), -1)&#13;&#10;THEN AVG([firearm_homicide_rate])&#13;&#10;ELSE NULL&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='EvidenceLawDot' datatype='real' name='[Calculation_0599237687500815]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Calculation_0599237687087117]) &gt; LOOKUP(SUM([Calculation_0599237687087117]), -1)&#13;&#10;THEN AVG([firearm_homicide_rate])&#13;&#10;ELSE NULL&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='LawTypeDot' datatype='real' name='[Calculation_0599237690941456]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([BigLawIncreaseDot (copy)_0599237686935564]) &gt; LOOKUP(SUM([BigLawIncreaseDot (copy)_0599237686935564]), -1) &#13;&#10;    OR SUM([Calculation_0599237687087117]) &gt; LOOKUP(SUM([Calculation_0599237687087117]), -1)&#13;&#10;    THEN AVG([firearm_homicide_rate])&#13;&#10;ELSE NULL&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='LawTypeDotColor' datatype='string' name='[Calculation_0599237691965457]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([BigLawIncreaseDot (copy)_0599237686935564]) &gt; LOOKUP(SUM([BigLawIncreaseDot (copy)_0599237686935564]), -1) &#13;&#10;    AND SUM([Calculation_0599237687087117]) &gt; LOOKUP(SUM([Calculation_0599237687087117]), -1)&#13;&#10;    THEN &quot;Both&quot;&#13;&#10;ELSEIF SUM([BigLawIncreaseDot (copy)_0599237686935564]) &gt; LOOKUP(SUM([BigLawIncreaseDot (copy)_0599237686935564]), -1)&#13;&#10;    THEN &quot;Popular Laws&quot;&#13;&#10;ELSEIF SUM([Calculation_0599237687087117]) &gt; LOOKUP(SUM([Calculation_0599237687087117]), -1)&#13;&#10;    THEN &quot;Evidence Laws&quot;&#13;&#10;ELSE NULL&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
