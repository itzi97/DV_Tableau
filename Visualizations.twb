        <column alias='Law Categories' caption='P LawColorEncoding' datatype='string' name='[Parameter 3]' param-domain-type='list' role='measure' type='nominal' value='&quot;Law Type Group&quot;'>
          <calculation class='tableau' formula='&quot;Law Type Group&quot;' />
