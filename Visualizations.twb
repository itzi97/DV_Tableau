            <zone fixed-size='52' h='9000' id='5' is-fixed='true' type-v2='text' w='98334' x='833' y='1250'>
              <formatted-text>
                <run fontcolor='#000000' fontsize='22'>Do Firearm Laws Reduce Homicide Rates?</run>
              </formatted-text>
              <zone-style>
                <format attr='border-color' value='#b4b4b4' />
                <format attr='border-style' value='solid' />
                <format attr='border-width' value='1' />
                <format attr='margin' value='10' />
